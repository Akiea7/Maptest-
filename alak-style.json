{
  "version": 8,
  "name": "ALAK App Style",
  "metadata": {},
  "sources": {
    "openfreemap": {
      "type": "vector",
      "url": "https://tiles.openfreemap.org/planet.json"
    }
  },
  "glyphs": "https://tiles.openfreemap.org/fonts/{fontstack}/{range}.pbf",
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#E2E5E9"
      }
    },
    {
      "id": "park",
      "type": "fill",
      "source": "openfreemap",
      "source-layer": "park",
      "paint": {
        "fill-color": "#CFE1D4"
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "openfreemap",
      "source-layer": "water",
      "paint": {
        "fill-color": "#C3D8E6"
      }
    },
    {
      "id": "building",
      "type": "fill",
      "source": "openfreemap",
      "source-layer": "building",
      "paint": {
        "fill-color": "#D5D9DE",
        "fill-opacity": 0.8
      }
    },
    {
      "id": "road_minor_casing",
      "type": "line",
      "source": "openfreemap",
      "source-layer": "transportation",
      "filter": ["match", ["get", "class"], ["minor", "residential", "service", "path", "pedestrian"], true, false],
      "layout": {
        "line-join": "round",
        "line-cap": "round"
      },
      "paint": {
        "line-color": "#E2E5E9",
        "line-width": {
          "base": 1.2,
          "stops": [[13, 2], [20, 12]]
        }
      }
    },
    {
      "id": "road_minor",
      "type": "line",
      "source": "openfreemap",
      "source-layer": "transportation",
      "filter": ["match", ["get", "class"], ["minor", "residential", "service", "path", "pedestrian"], true, false],
      "layout": {
        "line-join": "round",
        "line-cap": "round"
      },
      "paint": {
        "line-color": "#FFFFFF",
        "line-width": {
          "base": 1.2,
          "stops": [[13, 1], [20, 9]]
        }
      }
    },
    {
      "id": "road_major_casing",
      "type": "line",
      "source": "openfreemap",
      "source-layer": "transportation",
      "filter": ["match", ["get", "class"], ["motorway", "trunk", "primary", "secondary", "tertiary"], true, false],
      "layout": {
        "line-join": "round",
        "line-cap": "round"
      },
      "paint": {
        "line-color": "#A5B1C2",
        "line-width": {
          "base": 1.2,
          "stops": [[10, 3], [20, 16]]
        }
      }
    },
    {
      "id": "road_major",
      "type": "line",
      "source": "openfreemap",
      "source-layer": "transportation",
      "filter": ["match", ["get", "class"], ["motorway", "trunk", "primary", "secondary", "tertiary"], true, false],
      "layout": {
        "line-join": "round",
        "line-cap": "round"
      },
      "paint": {
        "line-color": "#FDF2D6",
        "line-width": {
          "base": 1.2,
          "stops": [[10, 2], [20, 13]]
        }
      }
    },
    {
      "id": "road_name",
      "type": "symbol",
      "source": "openfreemap",
      "source-layer": "transportation_name",
      "layout": {
        "text-field": ["coalesce", ["get", "name:ar"], ["get", "name"]],
        "text-font": ["Noto Sans Regular"],
        "symbol-placement": "line",
        "text-size": {"stops": [[12, 10], [18, 14]]}
      },
      "paint": {
        "text-color": "#6b7280",
        "text-halo-color": "#ffffff",
        "text-halo-width": 2
      }
    },
    {
      "id": "place_label_city",
      "type": "symbol",
      "source": "openfreemap",
      "source-layer": "place",
      "filter": ["==", ["get", "class"], "city"],
      "layout": {
        "text-field": ["coalesce", ["get", "name:ar"], ["get", "name"]],
        "text-font": ["Noto Sans Bold"],
        "text-size": {"stops": [[8, 14], [16, 22]]}
      },
      "paint": {
        "text-color": "#1E3A8A",
        "text-halo-color": "#ffffff",
        "text-halo-width": 2
      }
    },
    {
      "id": "place_label_other",
      "type": "symbol",
      "source": "openfreemap",
      "source-layer": "place",
      "filter": ["!=", ["get", "class"], "city"],
      "layout": {
        "text-field": ["coalesce", ["get", "name:ar"], ["get", "name"]],
        "text-font": ["Noto Sans Regular"],
        "text-size": {"stops": [[10, 11], [16, 15]]}
      },
      "paint": {
        "text-color": "#4a4a4a",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1.5
      }
    }
  ]
}
