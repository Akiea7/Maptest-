{
  "version": 8,
  "sources": {
    "ne2_shaded": {
      "maxzoom": 6,
      "tileSize": 256,
      "tiles": [
        "https://tiles.openfreemap.org/natural_earth/ne2sr/{z}/{x}/{y}.png"
      ],
      "type": "raster"
    },
    "openmaptiles": {
      "type": "vector",
      "url": "https://tiles.openfreemap.org/planet"
    }
  },
  "sprite": "https://tiles.openfreemap.org/sprites/ofm_f384/ofm",
  "glyphs": "https://tiles.openfreemap.org/fonts/{fontstack}/{range}.pbf",
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#f0f2f5"
      }
    },
    {
      "id": "natural_earth",
      "type": "raster",
      "source": "ne2_shaded",
      "maxzoom": 7,
      "paint": {
        "raster-opacity": ["interpolate", ["exponential", 1.5], ["zoom"], 0, 0.6, 6, 0.1]
      }
    },
    {
      "id": "landuse_residential",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landuse",
      "maxzoom": 13,
      "filter": ["==", ["get", "class"], "residential"],
      "paint": {
        "fill-color": "#f4f6f8",
        "fill-opacity": 1
      }
    },
    {
      "id": "landuse_commercial_industrial",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landuse",
      "filter": [
        "any",
        ["==", ["get", "class"], "commercial"],
        ["==", ["get", "class"], "industrial"]
      ],
      "paint": {
        "fill-color": "#e8eaed",
        "fill-opacity": 1
      }
    },
    {
      "id": "landuse_military",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landuse",
      "filter": ["==", ["get", "class"], "military"],
      "paint": {
        "fill-color": "#e0c4c4",
        "fill-opacity": 1
      }
    },
    {
      "id": "aeroway_fill",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "aeroway",
      "filter": [
        "any",
        ["==", ["geometry-type"], "Polygon"],
        ["==", ["geometry-type"], "MultiPolygon"]
      ],
      "paint": {
        "fill-color": "#cdd4e6",
        "fill-opacity": 1
      }
    },
    {
      "id": "park_layer",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "park",
      "paint": {
        "fill-color": "#b5d6b2",
        "fill-opacity": 1
      }
    },
    {
      "id": "landcover_green",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "filter": [
        "any",
        ["==", ["get", "class"], "grass"],
        ["==", ["get", "class"], "wood"],
        ["==", ["get", "class"], "forest"],
        ["==", ["get", "class"], "scrub"],
        ["==", ["get", "class"], "farmland"],
        ["==", ["get", "class"], "meadow"]
      ],
      "paint": {
        "fill-color": "#b5d6b2",
        "fill-opacity": 1
      }
    },
    {
      "id": "landuse_green",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landuse",
      "filter": [
        "any",
        ["==", ["get", "class"], "grass"],
        ["==", ["get", "class"], "pitch"],
        ["==", ["get", "class"], "recreation_ground"],
        ["==", ["get", "class"], "cemetery"],
        ["==", ["get", "class"], "park"],
        ["==", ["get", "class"], "village_green"],
        ["==", ["get", "class"], "farmland"],
        ["==", ["get", "class"], "meadow"],
        ["==", ["get", "class"], "orchard"]
      ],
      "paint": {
        "fill-color": "#b5d6b2",
        "fill-opacity": 1
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "water",
      "filter": ["!=", ["get", "brunnel"], "tunnel"],
      "paint": {
        "fill-color": "#D6EAF8",
        "fill-opacity": 1
      }
    },
    {
      "id": "waterway_river",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "waterway",
      "filter": ["all", ["==", ["get", "class"], "river"], ["!=", ["get", "brunnel"], "tunnel"]],
      "paint": {
        "line-color": "#D6EAF8",
        "line-width": ["interpolate", ["exponential", 1.2], ["zoom"], 11, 0.5, 20, 6]
      }
    },
    {
      "id": "road_minor_casing",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": [
        "all", 
        ["!=", ["get", "brunnel"], "tunnel"], 
        ["any", ["==", ["get", "class"], "minor"], ["==", ["get", "class"], "service"], ["==", ["get", "class"], "track"], ["==", ["get", "class"], "path"], ["==", ["get", "class"], "pedestrian"]]
      ],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#b0bcc8",
        "line-width": ["interpolate", ["exponential", 1.2], ["zoom"], 13, 1, 20, 18]
      }
    },
    {
      "id": "road_minor_fill",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": [
        "all", 
        ["!=", ["get", "brunnel"], "tunnel"], 
        ["any", ["==", ["get", "class"], "minor"], ["==", ["get", "class"], "service"], ["==", ["get", "class"], "track"], ["==", ["get", "class"], "path"], ["==", ["get", "class"], "pedestrian"]]
      ],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#ffffff",
        "line-width": ["interpolate", ["exponential", 1.2], ["zoom"], 13, 0.5, 20, 14]
      }
    },
    {
      "id": "road_major_casing",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": [
        "all", 
        ["!=", ["get", "brunnel"], "tunnel"], 
        ["any", ["==", ["get", "class"], "motorway"], ["==", ["get", "class"], "trunk"], ["==", ["get", "class"], "primary"], ["==", ["get", "class"], "secondary"], ["==", ["get", "class"], "tertiary"]]
      ],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#9ab0c4",
        "line-width": ["interpolate", ["exponential", 1.2], ["zoom"], 5, 1, 14, 6, 20, 26]
      }
    },
    {
      "id": "road_major_fill",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": [
        "all", 
        ["!=", ["get", "brunnel"], "tunnel"], 
        ["any", ["==", ["get", "class"], "motorway"], ["==", ["get", "class"], "trunk"], ["==", ["get", "class"], "primary"], ["==", ["get", "class"], "secondary"], ["==", ["get", "class"], "tertiary"]]
      ],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#d4e4f2",
        "line-width": ["interpolate", ["exponential", 1.2], ["zoom"], 5, 0.5, 14, 4, 20, 20]
      }
    },
    {
      "id": "bridge_major_casing",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": [
        "all", 
        ["==", ["get", "brunnel"], "bridge"], 
        ["any", ["==", ["get", "class"], "motorway"], ["==", ["get", "class"], "trunk"], ["==", ["get", "class"], "primary"], ["==", ["get", "class"], "secondary"], ["==", ["get", "class"], "tertiary"]]
      ],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#9ab0c4",
        "line-width": ["interpolate", ["exponential", 1.2], ["zoom"], 5, 1, 14, 6, 20, 26]
      }
    },
    {
      "id": "bridge_major_fill",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": [
        "all", 
        ["==", ["get", "brunnel"], "bridge"], 
        ["any", ["==", ["get", "class"], "motorway"], ["==", ["get", "class"], "trunk"], ["==", ["get", "class"], "primary"], ["==", ["get", "class"], "secondary"], ["==", ["get", "class"], "tertiary"]]
      ],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#d4e4f2",
        "line-width": ["interpolate", ["exponential", 1.2], ["zoom"], 5, 0.5, 14, 4, 20, 20]
      }
    },
    {
      "id": "building",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "building",
      "minzoom": 14,
      "maxzoom": 15,
      "paint": {
        "fill-color": "#E4E4E4",
        "fill-outline-color": "#D4D4D4",
        "fill-opacity": 0.6
      }
    },
    {
      "id": "building-3d",
      "type": "fill-extrusion",
      "source": "openmaptiles",
      "source-layer": "building",
      "minzoom": 15,
      "paint": {
        "fill-extrusion-base": ["coalesce", ["get", "render_min_height"], 0],
        "fill-extrusion-color": "#E4E4E4",
        "fill-extrusion-height": ["coalesce", ["get", "render_height"], 10],
        "fill-extrusion-opacity": 0.7
      }
    },
    {
      "id": "boundary_2",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "boundary",
      "filter": ["all", ["==", ["get", "admin_level"], 2], ["!=", ["get", "maritime"], 1], ["!=", ["get", "disputed"], 1]],
      "paint": {
        "line-color": "hsl(210,10%,60%)",
        "line-width": ["interpolate", ["linear"], ["zoom"], 3, 1, 12, 3]
      }
    },
    {
      "id": "poi_icons_labels",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "poi",
      "minzoom": 14,
      "filter": [
        "any",
        ["==", ["get", "class"], "restaurant"],
        ["==", ["get", "class"], "hospital"],
        ["==", ["get", "class"], "school"],
        ["==", ["get", "class"], "place_of_worship"],
        ["==", ["get", "class"], "pharmacy"],
        ["==", ["get", "class"], "fuel"],
        ["==", ["get", "class"], "atm"],
        ["==", ["get", "class"], "park"],
        ["==", ["get", "class"], "hotel"],
        ["==", ["get", "class"], "bank"],
        ["==", ["get", "class"], "shop"],
        ["==", ["get", "class"], "grocery"]
      ],
      "layout": {
        "icon-image": ["concat", ["get", "class"], "_11"],
        "icon-size": ["interpolate", ["linear"], ["zoom"], 14, 0.8, 18, 1.2],
        "text-field": ["coalesce", ["get", "name:ar"], ["get", "name"]],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 15, 10, 18, 14],
        "text-anchor": "top",
        "text-offset": [0, 0.8]
      },
      "paint": {
        "icon-opacity": ["interpolate", ["linear"], ["zoom"], 14, 0.2, 14.5, 1],
        "text-color": "#555555",
        "text-halo-color": "rgba(255,255,255,0.7)",
        "text-halo-width": 0.2,
        "text-opacity": ["interpolate", ["linear"], ["zoom"], 14.9, 0, 15, 1]
      }
    },
    {
      "id": "place_label_city",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "minzoom": 5,
      "filter": ["==", ["get", "class"], "city"],
      "layout": {
        "symbol-sort-key": ["get", "rank"],
        "text-field": ["coalesce", ["get", "name:ar"], ["get", "name"]],
        "text-font": ["Noto Sans Bold"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 5, 12, 10, 18],
        "text-anchor": "center",
        "text-padding": 10
      },
      "paint": {
        "text-color": "#333333",
        "text-halo-color": "rgba(255,255,255,0.8)",
        "text-halo-width": 0.2
      }
    },
    {
      "id": "place_label_town",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "minzoom": 8.5,
      "filter": ["==", ["get", "class"], "town"],
      "layout": {
        "symbol-sort-key": ["get", "rank"],
        "text-field": ["coalesce", ["get", "name:ar"], ["get", "name"]],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 8.5, 11, 14, 16],
        "text-anchor": "center",
        "text-padding": 8
      },
      "paint": {
        "text-color": "#444444",
        "text-halo-color": "rgba(255,255,255,0.8)",
        "text-halo-width": 0.2
      }
    },
    {
      "id": "place_label_village",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "minzoom": 10.5,
      "filter": ["==", ["get", "class"], "village"],
      "layout": {
        "symbol-sort-key": ["get", "rank"],
        "text-field": ["coalesce", ["get", "name:ar"], ["get", "name"]],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 10.5, 10, 15, 14],
        "text-anchor": "center",
        "text-padding": 5
      },
      "paint": {
        "text-color": "#555555",
        "text-halo-color": "rgba(255,255,255,0.8)",
        "text-halo-width": 0.2
      }
    },
    {
      "id": "place_label_suburb",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "minzoom": 12,
      "filter": ["==", ["get", "class"], "suburb"],
      "layout": {
        "symbol-sort-key": ["get", "rank"],
        "text-field": ["coalesce", ["get", "name:ar"], ["get", "name"]],
        "text-font": ["Noto Sans Italic"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 12, 11, 16, 15],
        "text-anchor": "center",
        "text-padding": 5
      },
      "paint": {
        "text-color": "#555555",
        "text-halo-color": "rgba(255,255,255,0.8)",
        "text-halo-width": 0.2
      }
    },
    {
      "id": "place_label_neighbourhood",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "minzoom": 13.5,
      "filter": ["==", ["get", "class"], "neighbourhood"],
      "layout": {
        "symbol-sort-key": ["get", "rank"],
        "text-field": ["coalesce", ["get", "name:ar"], ["get", "name"]],
        "text-font": ["Noto Sans Italic"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 13.5, 10, 17, 13],
        "text-anchor": "center",
        "text-padding": 5
      },
      "paint": {
        "text-color": "#666666",
        "text-halo-color": "rgba(255,255,255,0.8)",
        "text-halo-width": 0.2
      }
    },
    {
      "id": "road_label_major",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "transportation_name",
      "filter": [
        "any",
        ["==", ["get", "class"], "motorway"],
        ["==", ["get", "class"], "trunk"],
        ["==", ["get", "class"], "primary"],
        ["==", ["get", "class"], "secondary"]
      ],
      "minzoom": 10,
      "layout": {
        "symbol-placement": "line",
        "text-field": ["coalesce", ["get", "name:ar"], ["get", "name"]],
        "text-font": ["Noto Sans Bold"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 10, 10, 16, 14]
      },
      "paint": {
        "text-color": "#444444",
        "text-halo-color": "rgba(255,255,255,0.8)",
        "text-halo-width": 0.2
      }
    },
    {
      "id": "road_label_minor",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "transportation_name",
      "filter": [
        "any",
        ["==", ["get", "class"], "minor"],
        ["==", ["get", "class"], "service"],
        ["==", ["get", "class"], "track"],
        ["==", ["get", "class"], "tertiary"]
      ],
      "minzoom": 14.5,
      "layout": {
        "symbol-placement": "line",
        "text-field": ["coalesce", ["get", "name:ar"], ["get", "name"]],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 14.5, 9, 17, 12]
      },
      "paint": {
        "text-color": "#666666",
        "text-halo-color": "rgba(255,255,255,0.8)",
        "text-halo-width": 0.2
      }
    }
  ]
}
