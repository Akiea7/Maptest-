{
  "version": 8,
  "sources": {
    "ne2_shaded": {
      "maxzoom": 6,
      "tileSize": 256,
      "tiles": [
        "https://tiles.openfreemap.org/natural_earth/ne2sr/{z}/{x}/{y}.png"
      ],
      "type": "raster"
    },
    "openmaptiles": {
      "type": "vector",
      "url": "https://tiles.openfreemap.org/planet"
    }
  },
  "sprite": "https://tiles.openfreemap.org/sprites/ofm_f384/ofm",
  "glyphs": "https://tiles.openfreemap.org/fonts/{fontstack}/{range}.pbf",
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#f0f2f5"
      }
    },
    {
      "id": "natural_earth",
      "type": "raster",
      "source": "ne2_shaded",
      "maxzoom": 7,
      "paint": {
        "raster-opacity": ["interpolate", ["exponential", 1.5], ["zoom"], 0, 0.6, 6, 0.1]
      }
    },
    {
      "id": "park",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "park",
      "paint": {
        "fill-color": "#d1e6d3",
        "fill-opacity": 0.7
      }
    },
    {
      "id": "landuse_residential",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landuse",
      "maxzoom": 13,
      "filter": ["==", ["get", "class"], "residential"],
      "paint": {
        "fill-color": "#f7f9fa",
        "fill-opacity": 0.8
      }
    },
    {
      "id": "landuse_commercial_industrial",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landuse",
      "filter": ["match", ["get", "class"], ["commercial", "industrial"], true, false],
      "paint": {
        "fill-color": "#eceef0",
        "fill-opacity": 0.8
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "water",
      "filter": ["!=", ["get", "brunnel"], "tunnel"],
      "paint": {
        "fill-color": "#a1c2e6"
      }
    },
    {
      "id": "waterway_river",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "waterway",
      "filter": ["all", ["==", ["get", "class"], "river"], ["!=", ["get", "brunnel"], "tunnel"]],
      "paint": {
        "line-color": "#a1c2e6",
        "line-width": ["interpolate", ["exponential", 1.2], ["zoom"], 11, 0.5, 20, 6]
      }
    },
    {
      "id": "road_minor_casing",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["all", ["!=", ["get", "brunnel"], "tunnel"], ["match", ["get", "class"], ["minor", "service", "track"], true, false]],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#e1e4e8",
        "line-width": ["interpolate", ["exponential", 1.2], ["zoom"], 13, 1, 20, 18]
      }
    },
    {
      "id": "road_minor_fill",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["all", ["!=", ["get", "brunnel"], "tunnel"], ["match", ["get", "class"], ["minor", "service", "track"], true, false]],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#ffffff",
        "line-width": ["interpolate", ["exponential", 1.2], ["zoom"], 13, 0.5, 20, 14]
      }
    },
    {
      "id": "road_major_casing",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["all", ["!=", ["get", "brunnel"], "tunnel"], ["match", ["get", "class"], ["motorway", "trunk", "primary", "secondary", "tertiary"], true, false]],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#6b849e",
        "line-width": ["interpolate", ["exponential", 1.2], ["zoom"], 5, 1, 14, 6, 20, 26]
      }
    },
    {
      "id": "road_major_fill",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["all", ["!=", ["get", "brunnel"], "tunnel"], ["match", ["get", "class"], ["motorway", "trunk", "primary", "secondary", "tertiary"], true, false]],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#a5bbd1",
        "line-width": ["interpolate", ["exponential", 1.2], ["zoom"], 5, 0.5, 14, 4, 20, 20]
      }
    },
    {
      "id": "bridge_major_casing",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["all", ["==", ["get", "brunnel"], "bridge"], ["match", ["get", "class"], ["motorway", "trunk", "primary", "secondary", "tertiary"], true, false]],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#6b849e",
        "line-width": ["interpolate", ["exponential", 1.2], ["zoom"], 5, 1, 14, 6, 20, 26]
      }
    },
    {
      "id": "bridge_major_fill",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["all", ["==", ["get", "brunnel"], "bridge"], ["match", ["get", "class"], ["motorway", "trunk", "primary", "secondary", "tertiary"], true, false]],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#a5bbd1",
        "line-width": ["interpolate", ["exponential", 1.2], ["zoom"], 5, 0.5, 14, 4, 20, 20]
      }
    },
    {
      "id": "boundary_2",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "boundary",
      "filter": ["all", ["==", ["get", "admin_level"], 2], ["!=", ["get", "maritime"], 1], ["!=", ["get", "disputed"], 1]],
      "paint": {
        "line-color": "hsl(210,10%,60%)",
        "line-width": ["interpolate", ["linear"], ["zoom"], 3, 1, 12, 3]
      }
    },
    {
      "id": "place_label_city",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "minzoom": 5,
      "filter": ["==", ["get", "class"], "city"],
      "layout": {
        "symbol-sort-key": ["get", "rank"],
        "text-field": ["coalesce", ["get", "name:ar"], ["get", "name"]],
        "text-font": ["Noto Sans Bold"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 5, 12, 10, 18],
        "text-anchor": "center",
        "text-padding": 10
      },
      "paint": {
        "text-color": "#2c3e50",
        "text-halo-color": "rgba(255,255,255,0.9)",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "place_label_town",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "minzoom": 8.5,
      "filter": ["==", ["get", "class"], "town"],
      "layout": {
        "symbol-sort-key": ["get", "rank"],
        "text-field": ["coalesce", ["get", "name:ar"], ["get", "name"]],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 8.5, 11, 14, 16],
        "text-anchor": "center",
        "text-padding": 8
      },
      "paint": {
        "text-color": "#34495e",
        "text-halo-color": "rgba(255,255,255,0.9)",
        "text-halo-width": 1.2
      }
    },
    {
      "id": "place_label_village",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "minzoom": 10.5,
      "filter": ["==", ["get", "class"], "village"],
      "layout": {
        "symbol-sort-key": ["get", "rank"],
        "text-field": ["coalesce", ["get", "name:ar"], ["get", "name"]],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 10.5, 10, 15, 14],
        "text-anchor": "center",
        "text-padding": 5
      },
      "paint": {
        "text-color": "#4a5b6c",
        "text-halo-color": "rgba(255,255,255,0.8)",
        "text-halo-width": 1
      }
    },
    {
      "id": "place_label_suburb",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "minzoom": 12,
      "filter": ["==", ["get", "class"], "suburb"],
      "layout": {
        "symbol-sort-key": ["get", "rank"],
        "text-field": ["coalesce", ["get", "name:ar"], ["get", "name"]],
        "text-font": ["Noto Sans Italic"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 12, 11, 16, 15],
        "text-anchor": "center",
        "text-padding": 5
      },
      "paint": {
        "text-color": "#5d6d7e",
        "text-halo-color": "rgba(255,255,255,0.8)",
        "text-halo-width": 1
      }
    },
    {
      "id": "place_label_neighbourhood",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "minzoom": 13.5,
      "filter": ["==", ["get", "class"], "neighbourhood"],
      "layout": {
        "symbol-sort-key": ["get", "rank"],
        "text-field": ["coalesce", ["get", "name:ar"], ["get", "name"]],
        "text-font": ["Noto Sans Italic"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 13.5, 10, 17, 13],
        "text-anchor": "center",
        "text-padding": 5
      },
      "paint": {
        "text-color": "#5d6d7e",
        "text-halo-color": "rgba(255,255,255,0.8)",
        "text-halo-width": 1
      }
    },
    {
      "id": "road_label_major",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "transportation_name",
      "filter": ["match", ["get", "class"], ["motorway", "trunk", "primary", "secondary"], true, false],
      "minzoom": 10,
      "layout": {
        "symbol-placement": "line",
        "text-field": ["coalesce", ["get", "name:ar"], ["get", "name"]],
        "text-font": ["Noto Sans Bold"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 10, 10, 16, 14]
      },
      "paint": {
        "text-color": "#1c2833",
        "text-halo-color": "rgba(255,255,255,0.9)",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "road_label_minor",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "transportation_name",
      "filter": ["match", ["get", "class"], ["minor", "service", "track", "tertiary"], true, false],
      "minzoom": 14.5,
      "layout": {
        "symbol-placement": "line",
        "text-field": ["coalesce", ["get", "name:ar"], ["get", "name"]],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 14.5, 9, 17, 12]
      },
      "paint": {
        "text-color": "#7f8c8d",
        "text-halo-color": "rgba(255,255,255,0.9)",
        "text-halo-width": 1
      }
    }
  ]
}
