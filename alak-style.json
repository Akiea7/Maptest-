{
  "version": 8,
  "sources": {
    "ne2_shaded": {
      "maxzoom": 6,
      "tileSize": 256,
      "tiles": [
        "https://tiles.openfreemap.org/natural_earth/ne2sr/{z}/{x}/{y}.png"
      ],
      "type": "raster"
    },
    "openmaptiles": {
      "type": "vector",
      "url": "https://tiles.openfreemap.org/planet"
    }
  },
  "sprite": "https://tiles.openfreemap.org/sprites/ofm_f384/ofm",
  "glyphs": "https://tiles.openfreemap.org/fonts/{fontstack}/{range}.pbf",
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": ["interpolate", ["linear"], ["zoom"], 0, "#f0f2f5", 10, "#f4f6f8"]
      }
    },
    {
      "id": "natural_earth",
      "type": "raster",
      "source": "ne2_shaded",
      "maxzoom": 7,
      "paint": {
        "raster-opacity": ["interpolate", ["exponential", 1.5], ["zoom"], 0, 0.6, 6, 0.1]
      }
    },
    {
      "id": "park",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "park",
      "paint": {
        "fill-color": ["interpolate", ["linear"], ["zoom"], 0, "#d1e6d3", 10, "#cbe3ce"],
        "fill-opacity": 0.7
      }
    },
    {
      "id": "landuse_residential",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landuse",
      "maxzoom": 12,
      "filter": ["==", ["get", "class"], "residential"],
      "paint": {
        "fill-color": ["interpolate", ["linear"], ["zoom"], 0, "#f7f9fa", 10, "#f0f2f5"],
        "fill-opacity": 0.5
      }
    },
    {
      "id": "landuse_commercial",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landuse",
      "filter": ["==", ["get", "class"], "commercial"],
      "paint": {
        "fill-color": "#eceef0",
        "fill-opacity": 0.6
      }
    },
    {
      "id": "landuse_industrial",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landuse",
      "filter": ["==", ["get", "class"], "industrial"],
      "paint": {
        "fill-color": "#e8eaed",
        "fill-opacity": 0.6
      }
    },
    {
      "id": "landcover_wood",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "filter": ["==", ["get", "class"], "wood"],
      "paint": {
        "fill-color": "#d1e6d3",
        "fill-opacity": 0.6
      }
    },
    {
      "id": "landcover_grass",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "filter": ["==", ["get", "class"], "grass"],
      "paint": {
        "fill-color": "#d1e6d3",
        "fill-opacity": 0.6
      }
    },
    {
      "id": "landuse_hospital",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landuse",
      "filter": ["==", ["get", "class"], "hospital"],
      "paint": {
        "fill-color": "#fde4e4"
      }
    },
    {
      "id": "landuse_school",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landuse",
      "filter": ["==", ["get", "class"], "school"],
      "paint": {
        "fill-color": "#f0f4db"
      }
    },
    {
      "id": "waterway_river",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "waterway",
      "filter": ["all", ["==", ["get", "class"], "river"], ["!=", ["get", "brunnel"], "tunnel"]],
      "layout": {
        "line-cap": "round"
      },
      "paint": {
        "line-color": "#a1c2e6",
        "line-width": ["interpolate", ["exponential", 1.2], ["zoom"], 11, 0.5, 20, 6]
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "water",
      "filter": ["!=", ["get", "brunnel"], "tunnel"],
      "paint": {
        "fill-color": "#a1c2e6"
      }
    },
    {
      "id": "tunnel_casing",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["==", ["get", "brunnel"], "tunnel"],
      "layout": { "line-join": "round" },
      "paint": {
        "line-color": "#c8d0d8",
        "line-dasharray": [0.5, 0.25],
        "line-width": ["interpolate", ["exponential", 1.2], ["zoom"], 12, 1, 20, 15]
      }
    },
    {
      "id": "tunnel_fill",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["==", ["get", "brunnel"], "tunnel"],
      "layout": { "line-join": "round" },
      "paint": {
        "line-color": "#e8ebee",
        "line-width": ["interpolate", ["exponential", 1.2], ["zoom"], 12.5, 0, 20, 11.5]
      }
    },
    {
      "id": "road_minor_casing",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["all", ["match", ["get", "brunnel"], ["bridge", "tunnel"], false, true], ["match", ["get", "class"], ["minor", "service", "track"], true, false]],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#e1e4e8",
        "line-width": ["interpolate", ["exponential", 1.2], ["zoom"], 12, 0.5, 13, 1, 14, 4, 20, 20]
      }
    },
    {
      "id": "road_secondary_tertiary_casing",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["all", ["match", ["get", "brunnel"], ["bridge", "tunnel"], false, true], ["match", ["get", "class"], ["secondary", "tertiary"], true, false]],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#c8d0d8",
        "line-width": ["interpolate", ["exponential", 1.2], ["zoom"], 8, 1.5, 20, 17]
      }
    },
    {
      "id": "road_trunk_primary_casing",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["all", ["match", ["get", "brunnel"], ["bridge", "tunnel"], false, true], ["match", ["get", "class"], ["primary", "trunk", "motorway"], true, false]],
      "layout": { "line-join": "round", "line-cap": "round" },
      "paint": {
        "line-color": "#3b4d61",
        "line-width": ["interpolate", ["exponential", 1.2], ["zoom"], 5, 0.6, 6, 1, 7, 2.5, 20, 28]
      }
    },
    {
      "id": "road_minor",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["all", ["match", ["get", "brunnel"], ["bridge", "tunnel"], false, true], ["match", ["get", "class"], ["minor", "service", "track"], true, false]],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#ffffff",
        "line-width": ["interpolate", ["exponential", 1.2], ["zoom"], 13.5, 0, 14, 2.5, 20, 18]
      }
    },
    {
      "id": "road_secondary_tertiary",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["all", ["match", ["get", "brunnel"], ["bridge", "tunnel"], false, true], ["match", ["get", "class"], ["secondary", "tertiary"], true, false]],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#ffffff",
        "line-width": ["interpolate", ["exponential", 1.2], ["zoom"], 6.5, 0, 8, 0.5, 20, 13]
      }
    },
    {
      "id": "road_trunk_primary",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["all", ["match", ["get", "brunnel"], ["bridge", "tunnel"], false, true], ["match", ["get", "class"], ["primary", "trunk", "motorway"], true, false]],
      "layout": { "line-join": "round", "line-cap": "round" },
      "paint": {
        "line-color": "#6c8299",
        "line-width": ["interpolate", ["exponential", 1.2], ["zoom"], 5, 0, 7, 1.2, 20, 22]
      }
    },
    {
      "id": "bridge_casing",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["==", ["get", "brunnel"], "bridge"],
      "layout": { "line-join": "round" },
      "paint": {
        "line-color": "#3b4d61",
        "line-width": ["interpolate", ["exponential", 1.2], ["zoom"], 5, 0.6, 6, 1, 7, 2.5, 20, 28]
      }
    },
    {
      "id": "bridge_fill",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["==", ["get", "brunnel"], "bridge"],
      "layout": { "line-join": "round" },
      "paint": {
        "line-color": "#6c8299",
        "line-width": ["interpolate", ["exponential", 1.2], ["zoom"], 5, 0, 7, 1.2, 20, 22]
      }
    },
    {
      "id": "building",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "building",
      "minzoom": 13,
      "maxzoom": 14,
      "paint": {
        "fill-color": ["interpolate", ["linear"], ["zoom"], 13, "#dce1e6", 16, "#d3d8df"],
        "fill-outline-color": ["interpolate", ["linear"], ["zoom"], 13, "#b8c0c8", 16, "#b0b8c0"]
      }
    },
    {
      "id": "building-3d",
      "type": "fill-extrusion",
      "source": "openmaptiles",
      "source-layer": "building",
      "minzoom": 14,
      "paint": {
        "fill-extrusion-base": ["coalesce", ["get", "render_min_height"], 0],
        "fill-extrusion-color": ["interpolate", ["linear"], ["zoom"], 13, "#dce1e6", 16, "#d3d8df"],
        "fill-extrusion-height": ["coalesce", ["get", "render_height"], 10],
        "fill-extrusion-opacity": 0.8
      }
    },
    {
      "id": "boundary_2",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "boundary",
      "filter": ["all", ["==", ["get", "admin_level"], 2], ["!=", ["get", "maritime"], 1], ["!=", ["get", "disputed"], 1]],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "hsl(210,10%,60%)",
        "line-opacity": ["interpolate", ["linear"], ["zoom"], 0, 0.4, 4, 1],
        "line-width": ["interpolate", ["linear"], ["zoom"], 3, 1, 5, 1.2, 12, 3]
      }
    },
    {
      "id": "water_name_line_label",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "water_name",
      "minzoom": 10,
      "filter": ["match", ["geometry-type"], ["LineString", "MultiLineString", "Point"], true, false],
      "layout": {
        "symbol-placement": "line",
        "text-field": ["coalesce", ["get", "name:ar"], ["get", "name"], ["get", "name:en"]],
        "text-font": ["Noto Sans Italic"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 10, 12, 15, 16]
      },
      "paint": {
        "text-color": "#496991",
        "text-halo-color": "rgba(255,255,255,0.7)",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "place_label_city",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "minzoom": 5,
      "filter": ["==", ["get", "class"], "city"],
      "layout": {
        "symbol-sort-key": ["get", "rank"],
        "text-field": ["coalesce", ["get", "name:ar"], ["get", "name"], ["get", "name:en"]],
        "text-font": ["Noto Sans Bold"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 5, 12, 10, 18],
        "text-anchor": "center",
        "text-padding": 10
      },
      "paint": {
        "text-color": "#2c3e50",
        "text-halo-color": "rgba(255,255,255,0.9)",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "place_label_town",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "minzoom": 8.5,
      "filter": ["==", ["get", "class"], "town"],
      "layout": {
        "symbol-sort-key": ["get", "rank"],
        "text-field": ["coalesce", ["get", "name:ar"], ["get", "name"], ["get", "name:en"]],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 8.5, 11, 14, 16],
        "text-anchor": "center",
        "text-padding": 8
      },
      "paint": {
        "text-color": "#34495e",
        "text-halo-color": "rgba(255,255,255,0.9)",
        "text-halo-width": 1.2
      }
    },
    {
      "id": "place_label_village",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "minzoom": 10.5,
      "filter": ["==", ["get", "class"], "village"],
      "layout": {
        "symbol-sort-key": ["get", "rank"],
        "text-field": ["coalesce", ["get", "name:ar"], ["get", "name"], ["get", "name:en"]],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 10.5, 10, 15, 14],
        "text-anchor": "center",
        "text-padding": 5
      },
      "paint": {
        "text-color": "#4a5b6c",
        "text-halo-color": "rgba(255,255,255,0.8)",
        "text-halo-width": 1
      }
    },
    {
      "id": "place_label_suburb",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "minzoom": 12,
      "filter": ["==", ["get", "class"], "suburb"],
      "layout": {
        "symbol-sort-key": ["get", "rank"],
        "text-field": ["coalesce", ["get", "name:ar"], ["get", "name"], ["get", "name:en"]],
        "text-font": ["Noto Sans Italic"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 12, 11, 16, 15],
        "text-anchor": "center",
        "text-padding": 5
      },
      "paint": {
        "text-color": "#5d6d7e",
        "text-halo-color": "rgba(255,255,255,0.8)",
        "text-halo-width": 1
      }
    },
    {
      "id": "place_label_neighbourhood",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "minzoom": 13.5,
      "filter": ["==", ["get", "class"], "neighbourhood"],
      "layout": {
        "symbol-sort-key": ["get", "rank"],
        "text-field": ["coalesce", ["get", "name:ar"], ["get", "name"], ["get", "name:en"]],
        "text-font": ["Noto Sans Italic"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 13.5, 10, 17, 13],
        "text-anchor": "center",
        "text-padding": 5
      },
      "paint": {
        "text-color": "#5d6d7e",
        "text-halo-color": "rgba(255,255,255,0.8)",
        "text-halo-width": 1
      }
    },
    {
      "id": "road_label_motorway_trunk",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "transportation_name",
      "filter": ["match", ["get", "class"], ["motorway", "trunk", "primary"], true, false],
      "minzoom": 9,
      "layout": {
        "symbol-placement": "line",
        "text-field": ["coalesce", ["get", "name:ar"], ["get", "name"], ["get", "name:en"]],
        "text-font": ["Noto Sans Bold"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 9, 10, 16, 14]
      },
      "paint": {
        "text-color": "#1c2833",
        "text-halo-color": "rgba(255,255,255,0.9)",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "road_label_primary_secondary",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "transportation_name",
      "filter": ["match", ["get", "class"], ["secondary", "tertiary"], true, false],
      "minzoom": 12,
      "layout": {
        "symbol-placement": "line",
        "text-field": ["coalesce", ["get", "name:ar"], ["get", "name"], ["get", "name:en"]],
        "text-font": ["Noto Sans Bold"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 12, 10, 16, 13]
      },
      "paint": {
        "text-color": "#34495e",
        "text-halo-color": "rgba(255,255,255,0.9)",
        "text-halo-width": 1.2
      }
    },
    {
      "id": "road_label_minor",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "transportation_name",
      "filter": ["match", ["get", "class"], ["minor", "service", "track"], true, false],
      "minzoom": 14.5,
      "layout": {
        "symbol-placement": "line",
        "text-field": ["coalesce", ["get", "name:ar"], ["get", "name"], ["get", "name:en"]],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 14.5, 9, 17, 12]
      },
      "paint": {
        "text-color": "#7f8c8d",
        "text-halo-color": "rgba(255,255,255,0.9)",
        "text-halo-width": 1
      }
    }
  ]
}
