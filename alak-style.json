{
  "version": 8,
  "sources": {
    "ne2_shaded": {
      "maxzoom": 6,
      "tileSize": 256,
      "tiles": ["https://tiles.openfreemap.org/natural_earth/ne2sr/{z}/{x}/{y}.png"],
      "type": "raster"
    },
    "openmaptiles": {
      "type": "vector",
      "url": "https://tiles.openfreemap.org/planet"
    }
  },
  "sprite": "https://tiles.openfreemap.org/sprites/ofm_f384/ofm",
  "glyphs": "https://tiles.openfreemap.org/fonts/{fontstack}/{range}.pbf",
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": ["interpolate", ["linear"], ["zoom"], 0, "#f0f0f0", 10, "#f8f4f0"]
      }
    },
    {
      "id": "natural_earth",
      "type": "raster",
      "source": "ne2_shaded",
      "maxzoom": 7,
      "paint": {
        "raster-opacity": ["interpolate", ["exponential", 1.5], ["zoom"], 0, 0.6, 6, 0.1]
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "water",
      "filter": ["!=", ["get", "brunnel"], "tunnel"],
      "paint": { "fill-color": "#a0c8f0" }
    },
    {
      "id": "landuse_optimized",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landuse",
      "filter": ["match", ["get", "class"], ["residential", "commercial", "industrial", "cemetery", "hospital", "school", "stadium", "pitch"], true, false],
      "paint": {
        "fill-color": [
          "match", ["get", "class"],
          "residential", "#f0f0f0",
          "commercial", "#fdf2e9",
          "industrial", "#f0f2fd",
          "cemetery", "#eaebe0",
          "hospital", "#fde",
          "school", "#eae8d4",
          "stadium", "#d8e8c8",
          "pitch", "#dee3cd",
          "#f0f0f0"
        ],
        "fill-opacity": 0.4
      }
    },
    {
      "id": "landcover_optimized",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "filter": ["match", ["get", "class"], ["wood", "grass", "scrub", "snow", "wetland", "crop", "sand"], true, false],
      "paint": {
        "fill-color": [
          "match", ["get", "class"],
          "wood", "#cfe1d4",
          "grass", "#d8e8c8",
          "scrub", "#e0eacc",
          "snow", "#fbfdff",
          "wetland", "#d0e4cb",
          "crop", "#e9eace",
          "sand", "#f7efc3",
          "#f0f0f0"
        ],
        "fill-opacity": 0.5
      }
    },
    {
      "id": "park",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "park",
      "paint": { "fill-color": "#d8e8c8", "fill-opacity": 0.7 }
    },
    {
      "id": "building",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "building",
      "minzoom": 13,
      "paint": {
        "fill-color": "#d5d9de",
        "fill-outline-color": "#b8bec5",
        "fill-opacity": 0.8
      }
    },
    {
      "id": "waterway_river",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "waterway",
      "filter": ["all", ["==", ["get", "class"], "river"], ["!=", ["get", "brunnel"], "tunnel"]],
      "paint": { "line-color": "#a0c8f0", "line-width": ["interpolate", ["exponential", 1.2], ["zoom"], 11, 0.5, 20, 6] }
    },
    {
      "id": "tunnel_casing",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["==", ["get", "brunnel"], "tunnel"],
      "layout": { "line-join": "round" },
      "paint": {
        "line-color": "#cfcdca",
        "line-dasharray": [0.5, 0.25],
        "line-width": ["interpolate", ["exponential", 1.2], ["zoom"], 12, 1, 20, 15]
      }
    },
    {
      "id": "tunnel_fill",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["==", ["get", "brunnel"], "tunnel"],
      "layout": { "line-join": "round" },
      "paint": {
        "line-color": "#fff",
        "line-width": ["interpolate", ["exponential", 1.2], ["zoom"], 12.5, 0, 20, 11.5]
      }
    },
    {
      "id": "road_casing",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["!=", ["get", "brunnel"], "tunnel"],
      "layout": { "line-join": "round", "line-cap": "round" },
      "paint": {
        "line-color": [
          "match", ["get", "class"],
          ["motorway", "trunk", "primary", "secondary", "tertiary"], "#e9ac77",
          "#cfcdca"
        ],
        "line-width": ["interpolate", ["exponential", 1.2], ["zoom"], 5, 0.4, 14, 4, 20, 22]
      }
    },
    {
      "id": "road_fill",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["!=", ["get", "brunnel"], "tunnel"],
      "layout": { "line-join": "round", "line-cap": "round" },
      "paint": {
        "line-color": [
          "match", ["get", "class"],
          "motorway", "#fc8",
          ["trunk", "primary"], "#fea",
          ["secondary", "tertiary"], "#fff4c6",
          "#ffffff"
        ],
        "line-width": ["interpolate", ["exponential", 1.2], ["zoom"], 5, 0, 14, 2.5, 20, 18]
      }
    },
    {
      "id": "road_one_way_arrow",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "minzoom": 16,
      "filter": ["==", ["get", "oneway"], 1],
      "layout": { "icon-image": "arrow", "symbol-placement": "line" }
    },
    {
      "id": "road_one_way_arrow_opposite",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "minzoom": 16,
      "filter": ["==", ["get", "oneway"], -1],
      "layout": { "icon-image": "arrow", "icon-rotate": 180, "symbol-placement": "line" }
    },
    {
      "id": "boundary_country",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "boundary",
      "filter": ["==", ["get", "admin_level"], 2],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "hsl(248, 1%, 41%)",
        "line-opacity": ["interpolate", ["linear"], ["zoom"], 0, 0.4, 4, 1],
        "line-width": ["interpolate", ["linear"], ["zoom"], 3, 1, 12, 3]
      }
    },
    {
      "id": "boundary_state",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "boundary",
      "filter": ["all", [">=", ["get", "admin_level"], 3], ["<=", ["get", "admin_level"], 4]],
      "paint": {
        "line-color": "hsl(0, 0%, 70%)",
        "line-dasharray": [2, 1],
        "line-width": ["interpolate", ["linear", 1], ["zoom"], 7, 1, 11, 2]
      }
    },
    {
      "id": "place_label_city",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "filter": ["==", ["get", "class"], "city"],
      "layout": {
        "text-field": ["coalesce", ["get", "name:ar"], ["get", "name:en"], ["get", "name"]],
        "text-font": ["Noto Sans Bold"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 6, 12, 12, 18],
        "text-anchor": "center"
      },
      "paint": {
        "text-color": "hsl(0, 0%, 15%)",
        "text-halo-color": "hsl(0, 0%, 100%)",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "place_label_town",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "filter": ["==", ["get", "class"], "town"],
      "layout": {
        "text-field": ["coalesce", ["get", "name:ar"], ["get", "name:en"], ["get", "name"]],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 8, 11, 14, 16],
        "text-anchor": "center"
      },
      "paint": {
        "text-color": "hsl(0, 0%, 25%)",
        "text-halo-color": "hsl(0, 0%, 100%)",
        "text-halo-width": 1.2
      }
    },
    {
      "id": "place_label_neighbourhood",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "minzoom": 11,
      "filter": ["match", ["get", "class"], ["suburb", "neighbourhood", "village"], true, false],
      "layout": {
        "text-field": ["coalesce", ["get", "name:ar"], ["get", "name:en"], ["get", "name"]],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 11, 12, 16, 15],
        "text-anchor": "center"
      },
      "paint": {
        "text-color": "hsl(0, 0%, 35%)",
        "text-halo-color": "hsl(0, 0%, 100%)",
        "text-halo-width": 1.2
      }
    },
    {
      "id": "road_label",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "transportation_name",
      "filter": ["match", ["geometry-type"], ["LineString", "MultiLineString"], true, false],
      "layout": {
        "symbol-placement": "line",
        "text-field": ["coalesce", ["get", "name:ar"], ["get", "name:en"], ["get", "name"]],
        "text-font": [
          "match", ["get", "class"],
          ["motorway", "trunk", "primary", "secondary", "tertiary"], ["Noto Sans Bold"],
          ["Noto Sans Regular"]
        ],
        "text-rotation-alignment": "map",
        "text-size": ["interpolate", ["linear"], ["zoom"], 12, 10, 16, 14]
      },
      "paint": {
        "text-color": [
          "match", ["get", "class"],
          ["motorway", "trunk", "primary", "secondary", "tertiary"], "hsl(0, 0%, 25%)",
          "hsl(0, 0%, 40%)"
        ],
        "text-halo-color": "hsl(0, 0%, 100%)",
        "text-halo-width": 1.2
      }
    }
  ]
}
