{
  "version": 8,
  "name": "My App Map Style",
  "metadata": {
    "mapbox:autocomposite": false,
    "maputnik:renderer": "mljs"
  },
  "sources": {
    "osm-vector": {
      "type": "vector",
      "url": "https://api.maptiler.com/tiles/v3/tiles.json?key=YOUR_API_KEY_HERE"
    }
  },
  "sprite": "https://api.maptiler.com/maps/streets/sprite",
  "glyphs": "https://api.maptiler.com/fonts/{fontstack}/{range}.pbf?key=YOUR_API_KEY_HERE",
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#f8f4f0"
      }
    },
    {
      "id": "landcover-grass",
      "type": "fill",
      "source": "osm-vector",
      "source-layer": "landcover",
      "filter": ["==", "class", "grass"],
      "paint": {
        "fill-color": "#d8e8c8",
        "fill-opacity": 0.8
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "osm-vector",
      "source-layer": "water",
      "paint": {
        "fill-color": "#a0c8f0"
      }
    },
    {
      "id": "roads-secondary",
      "type": "line",
      "source": "osm-vector",
      "source-layer": "transportation",
      "filter": ["in", "class", "secondary", "tertiary"],
      "paint": {
        "line-color": "#ffffff",
        "line-width": 1.5
      }
    },
    {
      "id": "roads-primary",
      "type": "line",
      "source": "osm-vector",
      "source-layer": "transportation",
      "filter": ["==", "class", "primary"],
      "paint": {
        "line-color": "#ffdf76",
        "line-width": 2
      }
    },
    {
      "id": "roads-highway",
      "type": "line",
      "source": "osm-vector",
      "source-layer": "transportation",
      "filter": ["==", "class", "motorway"],
      "paint": {
        "line-color": "#fc8",
        "line-width": 2.5
      }
    },
    {
      "id": "buildings",
      "type": "fill",
      "source": "osm-vector",
      "source-layer": "building",
      "paint": {
        "fill-color": "#e0dfdf",
        "fill-outline-color": "#cfcfcf"
      }
    },
    {
      "id": "place-labels",
      "type": "symbol",
      "source": "osm-vector",
      "source-layer": "place",
      "minzoom": 5,
      "layout": {
        "text-field": "{name:latin}\n{name:nonlatin}",
        "text-font": ["Noto Sans Regular"],
        "text-size": 12,
        "text-anchor": "center"
      },
      "paint": {
        "text-color": "#333333",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1.5
      }
    }
  ]
}
