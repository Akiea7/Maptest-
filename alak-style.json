{
  "version": 8,
  "sources": {
    "ne2_shaded": {
      "maxzoom": 6,
      "tileSize": 256,
      "tiles": [
        "https://tiles.openfreemap.org/natural_earth/ne2sr/{z}/{x}/{y}.png"
      ],
      "type": "raster"
    },
    "openmaptiles": {
      "type": "vector",
      "url": "https://tiles.openfreemap.org/planet"
    }
  },
  "sprite": "https://tiles.openfreemap.org/sprites/ofm_f384/ofm",
  "glyphs": "https://tiles.openfreemap.org/fonts/{fontstack}/{range}.pbf",
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#f2f4f5"
      }
    },
    {
      "id": "natural_earth",
      "type": "raster",
      "source": "ne2_shaded",
      "maxzoom": 7,
      "paint": {
        "raster-opacity": ["interpolate", ["exponential", 1.5], ["zoom"], 0, 0.6, 6, 0.1]
      }
    },
    {
      "id": "park",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "park",
      "paint": {
        "fill-color": "#D5ECD0",
        "fill-opacity": 0.9
      }
    },
    {
      "id": "landuse_residential",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landuse",
      "maxzoom": 13,
      "filter": ["==", ["get", "class"], "residential"],
      "paint": {
        "fill-color": "#f7f9fa",
        "fill-opacity": 0.8
      }
    },
    {
      "id": "landuse_commercial_industrial",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landuse",
      "filter": ["match", ["get", "class"], ["commercial", "industrial"], true, false],
      "paint": {
        "fill-color": "#E4E4E4",
        "fill-opacity": 0.5
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "water",
      "filter": ["!=", ["get", "brunnel"], "tunnel"],
      "paint": {
        "fill-color": "#D6EAF8"
      }
    },
    {
      "id": "waterway_river",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "waterway",
      "filter": ["all", ["==", ["get", "class"], "river"], ["!=", ["get", "brunnel"], "tunnel"]],
      "paint": {
        "line-color": "#D6EAF8",
        "line-width": ["interpolate", ["exponential", 1.2], ["zoom"], 11, 0.5, 20, 6]
      }
    },
    {
      "id": "road_minor_casing",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "minzoom": 12,
      "filter": ["all", ["!=", ["get", "brunnel"], "tunnel"], ["match", ["get", "class"], ["minor", "service", "track"], true, false]],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#e1e4e8",
        "line-width": ["interpolate", ["exponential", 1.2], ["zoom"], 12, 1, 20, 18]
      }
    },
    {
      "id": "road_minor_fill",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "minzoom": 12,
      "filter": ["all", ["!=", ["get", "brunnel"], "tunnel"], ["match", ["get", "class"], ["minor", "service", "track"], true, false]],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#FFFFFF",
        "line-width": ["interpolate", ["exponential", 1.2], ["zoom"], 12, 0.5, 20, 14]
      }
    },
    {
      "id": "road_major_casing",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["all", ["!=", ["get", "brunnel"], "tunnel"], ["match", ["get", "class"], ["motorway", "trunk", "primary", "secondary", "tertiary"], true, false]],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#AEB8C4",
        "line-width": ["interpolate", ["exponential", 1.2], ["zoom"], 5, 1, 14, 6, 20, 26]
      }
    },
    {
      "id": "road_major_fill",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["all", ["!=", ["get", "brunnel"], "tunnel"], ["match", ["get", "class"], ["motorway", "trunk", "primary", "secondary", "tertiary"], true, false]],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#F8E7A5",
        "line-width": ["interpolate", ["exponential", 1.2], ["zoom"], 5, 0.5, 14, 4, 20, 20]
      }
    },
    {
      "id": "bridge_major_casing",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["all", ["==", ["get", "brunnel"], "bridge"], ["match", ["get", "class"], ["motorway", "trunk", "primary", "secondary", "tertiary"], true, false]],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#AEB8C4",
        "line-width": ["interpolate", ["exponential", 1.2], ["zoom"], 5, 1, 14, 6, 20, 26]
      }
    },
    {
      "id": "bridge_major_fill",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["all", ["==", ["get", "brunnel"], "bridge"], ["match", ["get", "class"], ["motorway", "trunk", "primary", "secondary", "tertiary"], true, false]],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#F8E7A5",
        "line-width": ["interpolate", ["exponential", 1.2], ["zoom"], 5, 0.5, 14, 4, 20, 20]
      }
    },
    {
      "id": "building",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "building",
      "minzoom": 14,
      "maxzoom": 15,
      "paint": {
        "fill-color": "#E4E4E4",
        "fill-outline-color": "#D0D0D0"
      }
    },
    {
      "id": "building-3d",
      "type": "fill-extrusion",
      "source": "openmaptiles",
      "source-layer": "building",
      "minzoom": 15,
      "paint": {
        "fill-extrusion-base": ["coalesce", ["get", "render_min_height"], 0],
        "fill-extrusion-color": "#E4E4E4",
        "fill-extrusion-height": ["coalesce", ["get", "render_height"], 10],
        "fill-extrusion-opacity": 0.8
      }
    },
    {
      "id": "boundary_2",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "boundary",
      "filter": ["all", ["==", ["get", "admin_level"], 2], ["!=", ["get", "maritime"], 1], ["!=", ["get", "disputed"], 1]],
      "paint": {
        "line-color": "hsl(210,10%,60%)",
        "line-width": ["interpolate", ["linear"], ["zoom"], 3, 1, 12, 3]
      }
    },
    {
      "id": "water_name_line_label",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "water_name",
      "minzoom": 10,
      "filter": ["match", ["geometry-type"], ["LineString", "MultiLineString", "Point"], true, false],
      "layout": {
        "symbol-placement": "line",
        "text-field": ["coalesce", ["get", "name:ar"], ["get", "name"]],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 10, 12, 15, 16]
      },
      "paint": {
        "text-color": "#555555",
        "text-halo-color": "#ffffff",
        "text-halo-width": 2
      }
    },
    {
      "id": "place_label_city",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "minzoom": 5,
      "filter": ["==", ["get", "class"], "city"],
      "layout": {
        "symbol-sort-key": ["get", "rank"],
        "text-field": ["coalesce", ["get", "name:ar"], ["get", "name"]],
        "text-font": ["Noto Sans Bold"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 5, 14, 10, 20],
        "text-anchor": "center",
        "text-padding": 10
      },
      "paint": {
        "text-color": "#555555",
        "text-halo-color": "#ffffff",
        "text-halo-width": 2
      }
    },
    {
      "id": "place_label_town_village",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "minzoom": 10,
      "filter": ["match", ["get", "class"], ["town", "village"], true, false],
      "layout": {
        "symbol-sort-key": ["get", "rank"],
        "text-field": ["coalesce", ["get", "name:ar"], ["get", "name"]],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 10, 12, 14, 16],
        "text-anchor": "center",
        "text-padding": 8
      },
      "paint": {
        "text-color": "#555555",
        "text-halo-color": "#ffffff",
        "text-halo-width": 2
      }
    },
    {
      "id": "place_label_suburb",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "minzoom": 14,
      "filter": ["match", ["get", "class"], ["suburb", "neighbourhood"], true, false],
      "layout": {
        "symbol-sort-key": ["get", "rank"],
        "text-field": ["coalesce", ["get", "name:ar"], ["get", "name"]],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 14, 13, 16, 16],
        "text-anchor": "center",
        "text-padding": 5
      },
      "paint": {
        "text-color": "#555555",
        "text-halo-color": "#ffffff",
        "text-halo-width": 2
      }
    },
    {
      "id": "road_label_major",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "transportation_name",
      "filter": ["match", ["get", "class"], ["motorway", "trunk", "primary", "secondary"], true, false],
      "minzoom": 12,
      "layout": {
        "symbol-placement": "line",
        "text-field": ["coalesce", ["get", "name:ar"], ["get", "name"]],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 12, 11, 16, 15]
      },
      "paint": {
        "text-color": "#555555",
        "text-halo-color": "#ffffff",
        "text-halo-width": 2
      }
    },
    {
      "id": "road_label_minor",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "transportation_name",
      "filter": ["match", ["get", "class"], ["minor", "service", "track", "tertiary"], true, false],
      "minzoom": 14.5,
      "layout": {
        "symbol-placement": "line",
        "text-field": ["coalesce", ["get", "name:ar"], ["get", "name"]],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 14.5, 10, 17, 13]
      },
      "paint": {
        "text-color": "#555555",
        "text-halo-color": "#ffffff",
        "text-halo-width": 2
      }
    },
    {
      "id": "poi_labels",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "poi",
      "minzoom": 15,
      "layout": {
        "text-field": ["coalesce", ["get", "name:ar"], ["get", "name"]],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 15, 11, 18, 14],
        "text-anchor": "center",
        "text-padding": 5
      },
      "paint": {
        "text-color": "#7A7D86",
        "text-halo-color": "#ffffff",
        "text-halo-width": 2
      }
    }
  ]
}
